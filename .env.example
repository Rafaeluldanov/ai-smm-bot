AUTOPILOT_AUTO_CREATE_SCHEDULES=true
AUTOPILOT_AUTO_START_LIVE=false
AUTOPILOT_SHOW_ADVANCED_SETTINGS=false
AUTOPILOT_MIN_MEDIA_ASSETS=5
AUTOPILOT_RECOMMENDED_MEDIA_ASSETS=30
AUTOPILOT_DEFAULT_POSTS_PER_DAY=1
AUTOPILOT_DEFAULT_PUBLISH_TIME=10:00
AUTOPILOT_DEFAULT_TIMEZONE=Europe/Moscow

