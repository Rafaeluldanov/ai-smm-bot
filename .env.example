# --- Notification delivery sandbox: email/telegram/webhook + digest (v0.5.1) ---
# Внешняя доставка уведомлений как sandbox/mock: провайдеры по умолчанию mock и НИЧЕГО не
# отправляют. РЕАЛЬНАЯ доставка (SMTP/Telegram/webhook) ВЫКЛЮЧЕНА по умолчанию; dry-run по
# умолчанию; секреты читаются из окружения и в код/логи/UI не попадают.
NOTIFICATION_DELIVERY_ENABLED=true
NOTIFICATION_DELIVERY_DRY_RUN=true
NOTIFICATION_EXTERNAL_DELIVERY_ENABLED=false

NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_EMAIL_PROVIDER=mock
NOTIFICATION_EMAIL_LIVE_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

NOTIFICATION_TELEGRAM_ENABLED=false
NOTIFICATION_TELEGRAM_PROVIDER=mock
NOTIFICATION_TELEGRAM_LIVE_ENABLED=false
NOTIFICATION_TELEGRAM_BOT_TOKEN=
NOTIFICATION_TELEGRAM_DEFAULT_CHAT_ID=

# Telegram notification templates + chat binding (v0.5.4).
# РЕАЛЬНАЯ Telegram-доставка ВЫКЛЮЧЕНА по умолчанию: live send false, test send false, dry-run
# true. Требует ещё external+telegram live-флаги + verified binding. Bot token — только в env.
NOTIFICATION_TELEGRAM_TEMPLATES_ENABLED=true
NOTIFICATION_TELEGRAM_BINDING_ENABLED=true
NOTIFICATION_TELEGRAM_BINDING_TOKEN_BYTES=24
NOTIFICATION_TELEGRAM_BINDING_TOKEN_TTL_DAYS=30
NOTIFICATION_TELEGRAM_PARSE_MODE=none
NOTIFICATION_TELEGRAM_TEST_SEND_ENABLED=false
NOTIFICATION_TELEGRAM_TEST_SEND_DRY_RUN=true
NOTIFICATION_TELEGRAM_MAX_MESSAGE_CHARS=3900
NOTIFICATION_TELEGRAM_LIVE_SEND_ENABLED=false
NOTIFICATION_TELEGRAM_REQUIRE_VERIFIED_BINDING=true
NOTIFICATION_TELEGRAM_ALLOW_UNVERIFIED_TEST=false

# Telegram bot webhook/polling sandbox (v0.5.5).
# Incoming webhook endpoint включён для local/sandbox; РЕАЛЬНЫЕ Telegram API-вызовы
# (setWebhook/getUpdates/deleteWebhook) ВЫКЛЮЧЕНЫ по умолчанию (live false, dry-run true).
# Secret token / bot token — только в env (в примерах пусто).
NOTIFICATION_TELEGRAM_WEBHOOK_ENABLED=true
NOTIFICATION_TELEGRAM_WEBHOOK_LIVE_ENABLED=false
NOTIFICATION_TELEGRAM_WEBHOOK_SECRET_REQUIRED=false
