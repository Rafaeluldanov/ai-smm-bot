# Пример переменных окружения для AI-SMM-бота.
# Скопируйте файл в .env и заполните значения. РЕАЛЬНЫЕ ТОКЕНЫ В РЕПОЗИТОРИЙ НЕ ПОПАДАЮТ.
# Файл .env добавлен в .gitignore.

# --- Приложение ---
APP_NAME=ai-smm-bot
# APP_ENV: local | staging | production. В production эндпоинт /health/readiness
# предупреждает о не настроенных интеграциях и о SQLite вместо PostgreSQL.
APP_ENV=local

# --- Безопасность SaaS-платформы ---
# AUTH_TOKEN_SECRET — секрет будущей реальной auth (JWT/сессии); в production
# обязателен, dev-токен-заглушка недопустима. AUDIT_LOG_ENABLED — вести аудит действий.
# SECURITY_HIDE_LEGACY_PROJECTS_IN_PROD — прятать проекты без account_id в production.
# PAID_ACTIONS_ENFORCED — требовать баланс/списание для платных действий.
# SECURITY_REQUIRE_AUTH — форсировать авторизацию на защищённых роутах и вне production
# (в production включено всегда).
AUTH_TOKEN_SECRET=
AUDIT_LOG_ENABLED=true
SECURITY_HIDE_LEGACY_PROJECTS_IN_PROD=true
PAID_ACTIONS_ENFORCED=true
SECURITY_REQUIRE_AUTH=false

# --- Auth / session (v0.3.2) ---
# Access/refresh-токены (HMAC-SHA256). В production: AUTH_TOKEN_SECRET обязателен и
# надёжен (≥16 симв.), AUTH_ALLOW_DEV_TOKEN=false, AUTH_REQUIRE_AUTH=true,
# AUTH_COOKIE_SECURE=true — иначе приложение падает на старте/security-readiness.
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_SESSION_COOKIE_NAME=botfleet_session
AUTH_REFRESH_COOKIE_NAME=botfleet_refresh
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_HTTPONLY=true
AUTH_COOKIE_AUTH_ENABLED=false
AUTH_ALLOW_DEV_TOKEN=true
AUTH_REQUIRE_AUTH=false

# --- CSRF (для cookie-auth) ---
CSRF_PROTECTION_ENABLED=false
CSRF_COOKIE_NAME=botfleet_csrf

# --- Rate limiting (in-memory MVP; для распределённого prod — Redis) ---
RATE_LIMIT_ENABLED=false
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=120
RATE_LIMIT_PAYMENT_PER_MINUTE=30

# --- Security headers ---
SECURITY_HEADERS_ENABLED=true

# --- Хранилища ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_smm_bot
REDIS_URL=redis://localhost:6379/0

# --- Внешние интеграции (заполняются на соответствующих этапах) ---
# Яндекс Диск (Этап 2). Токен — OAuth-токен Яндекс.Диска; без него синхронизация
# недоступна (sync-эндпоинты вернут 503), но остальной API работает.
YANDEX_DISK_TOKEN=
YANDEX_DISK_BASE_URL=https://cloud-api.yandex.net/v1/disk
YANDEX_DISK_ROOT_PATH=/SMM_BOT
# Публичный режим Яндекс Диска (альтернатива OAuth-токену). Если включён,
# sync-media читает медиа по публичной ссылке без токена. Папки: внутри SMM
# лежат «Тион» и «Фабрика сувениров»; teeon видит только «Тион», fabric-souvenirs
# видит «Тион» + «Фабрика сувениров».
YANDEX_DISK_PUBLIC_MODE=false
YANDEX_DISK_PUBLIC_SMM_URL=
YANDEX_DISK_PUBLIC_ROOT_FOLDER=SMM
# Автопостинг (Этап 7). Без токенов реальная публикация недоступна (понятная
# ошибка), но планирование, API и тесты работают. Instagram на Этапе 7 не подключён.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHANNEL_ID=
VK_ACCESS_TOKEN=
VK_DEFAULT_GROUP_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Instagram Graph API / OAuth через Meta App. APP_ID / REDIRECT_URI / USER_ID —
# несекретные справочные значения; APP_SECRET и ACCESS_TOKEN — секреты (не коммитить,
# в UI показывается только факт наличия/маска). REDIRECT_URI пуст ⇒ выводится из
# PUBLIC_APP_URL. Публикация фото требует публичного HTTPS image_url.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=
INSTAGRAM_USER_ID=
# Видео-платформы (adapter-скелеты; live пока не реализован).
YOUTUBE_ACCESS_TOKEN=
YOUTUBE_CHANNEL_ID=
RUTUBE_ACCESS_TOKEN=
RUTUBE_CHANNEL_ID=

# Живая (РЕАЛЬНАЯ) публикация в соцсети. По умолчанию false — без этих флагов
# отправка невозможна (защита от случайной публикации). Для Instagram/YouTube/RuTube
# даже с флагом live пока не реализован (понятная ошибка); dry-run/preview работает.
TELEGRAM_LIVE_PUBLISHING_ENABLED=false
VK_LIVE_PUBLISHING_ENABLED=false
INSTAGRAM_LIVE_PUBLISHING_ENABLED=false
YOUTUBE_LIVE_PUBLISHING_ENABLED=false
RUTUBE_LIVE_PUBLISHING_ENABLED=false

# Максимум фото в одном Telegram-посте с альбомом (sendMediaGroup, до 10).
TELEGRAM_MEDIA_GROUP_MAX_PHOTOS=10

# --- VK API photo upload strategy (без OAuth/браузера) ---
# auto — сначала wall (photos.getWallUploadServer), при error 27 — album
# (photos.getUploadServer/photos.save в альбом группы). Варианты: auto|wall|album.
VK_PHOTO_UPLOAD_STRATEGY=auto
VK_PHOTO_ALBUM_ID=
VK_PHOTO_ALBUM_TITLE=AI SMM Bot uploads
VK_PHOTO_PROBE_ALLOW_UPLOAD=false

# --- SEO-заполнение VK-группы (SEO VK Group Setup) ---
# Реальные изменения оформления VK-группы (название/описание/статус/закреп/меню).
# По умолчанию false — apply работает только как preview/dry-run, реальные вызовы
# VK API оформления группы не выполняются. VK_GROUP_SETUP_ALLOWED_PROJECTS —
# список project_slug (через запятую), которым разрешено SEO-заполнение.
VK_GROUP_SETUP_LIVE_ENABLED=false
VK_GROUP_SETUP_ALLOWED_PROJECTS=teeon,fabric-souvenirs

# --- Публичный адрес приложения (для VK OAuth callback) ---
# Продакшн-домен с HTTPS. Из него выводится VK_OAUTH_REDIRECT_URI, если тот пуст.
PUBLIC_APP_URL=https://app.teeon.ru

# --- VK OAuth (подключение ПОЛЬЗОВАТЕЛЬСКОГО токена через кнопку) ---
# Standalone-приложение VK для OAuth: пользователь сам выдаёт доступ (scope
# wall,photos,groups,offline), фото грузятся его user-token, НЕ ключом сообщества.
# VK_APP_SECRET не логируется; полученный токен хранится в секрете ресурса (маска).
# VK требует HTTPS-redirect. Оставьте VK_OAUTH_REDIRECT_URI пустым — он выведется из
# PUBLIC_APP_URL + /integrations/vk/oauth/callback (для локали задайте PUBLIC_APP_URL
# или VK_OAUTH_REDIRECT_URI явно). В VK ID приложении добавьте базовый домен и этот URL.
VK_APP_ID=54671660
VK_APP_SECRET=
VK_OAUTH_REDIRECT_URI=

# --- AI-провайдер ---
AI_PROVIDER=stub
AI_API_KEY=
# Модель и цены токенов (USD за 1M токенов). Меняйте под реальный тариф провайдера —
# юнит-экономика пересчитается без правок кода. Значения ниже — ориентир.
AI_PRICING_MODEL=gpt-5.4-mini
AI_INPUT_USD_PER_1M=0.75
AI_OUTPUT_USD_PER_1M=4.50

# --- Биллинг / юнит-экономика (units — внутренняя валюта Botfleet) ---
# себестоимость_usd = in/1M*in_price + out/1M*out_price
# цена_клиента_usd  = себестоимость_usd * markup_multiplier
# units = max(min_units, ceil(цена_клиента_usd * usd_to_unit_rate))
BILLING_MARKUP_MULTIPLIER=2.0
BILLING_USD_TO_UNIT_RATE=100.0
BILLING_MIN_POST_UNITS=5
BILLING_MIN_ANALYTICS_UNITS=3
# Ориентировочная цена 1 unit в рублях (для суммы счёта; реальных платежей нет).
BILLING_UNIT_PRICE_RUB=1.0

# --- Аналитика: фиксированные цены по глубине (units за пост) ---
ANALYTICS_LIGHT_UNITS=10
ANALYTICS_STANDARD_UNITS=20
ANALYTICS_DEEP_UNITS=40

# --- Платежи (Россия). РЕАЛЬНЫЕ ПЛАТЕЖИ ВЫКЛЮЧЕНЫ по умолчанию ---
# Без PAYMENTS_LIVE_ENABLED=true все счета — mock/sandbox; баланс пополняется только
# после статуса paid (mock-pay/webhook). Секреты провайдеров НЕ коммитить: заполняются
# в реальном .env, в UI показываются только маской.
PAYMENTS_LIVE_ENABLED=false
PAYMENTS_DEFAULT_PROVIDER=mock
PAYMENTS_SUCCESS_RETURN_URL=
PAYMENTS_FAIL_RETURN_URL=
# YooKassa (sandbox skeleton)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=
# T-Bank / Тинькофф (sandbox skeleton)
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=
# CloudPayments (sandbox skeleton)
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=
# Robokassa (planned skeleton)
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=

# --- Улучшение медиа (Media Enhancement) ---
# Создание улучшенных КОПИЙ изображений (оригиналы не меняются). Локально, без AI.
MEDIA_ENHANCEMENT_ENABLED=false
MEDIA_ENHANCEMENT_STORAGE_DIR=backend/data/enhanced_media
MEDIA_ENHANCEMENT_MAX_IMAGE_MB=25
MEDIA_ENHANCEMENT_DEFAULT_PROFILE=social_safe
MEDIA_ENHANCEMENT_OUTPUT_FORMAT=jpg
MEDIA_ENHANCEMENT_JPEG_QUALITY=92
