# Пример переменных окружения для AI-SMM-бота.
# Скопируйте файл в .env и заполните значения. РЕАЛЬНЫЕ ТОКЕНЫ В РЕПОЗИТОРИЙ НЕ ПОПАДАЮТ.
# Файл .env добавлен в .gitignore.

# --- Приложение ---
APP_NAME=ai-smm-bot
# APP_ENV: local | staging | production. В production эндпоинт /health/readiness
# предупреждает о не настроенных интеграциях и о SQLite вместо PostgreSQL.
APP_ENV=local

# --- Безопасность SaaS-платформы ---
# AUTH_TOKEN_SECRET — секрет будущей реальной auth (JWT/сессии); в production
# обязателен, dev-токен-заглушка недопустима. AUDIT_LOG_ENABLED — вести аудит действий.
# SECURITY_HIDE_LEGACY_PROJECTS_IN_PROD — прятать проекты без account_id в production.
# PAID_ACTIONS_ENFORCED — требовать баланс/списание для платных действий.
# SECURITY_REQUIRE_AUTH — форсировать авторизацию на защищённых роутах и вне production
# (в production включено всегда).
AUTH_TOKEN_SECRET=
AUDIT_LOG_ENABLED=true
SECURITY_HIDE_LEGACY_PROJECTS_IN_PROD=true
PAID_ACTIONS_ENFORCED=true
SECURITY_REQUIRE_AUTH=false

# --- Auth / session (v0.3.2) ---
# Access/refresh-токены (HMAC-SHA256). В production: AUTH_TOKEN_SECRET обязателен и
# надёжен (≥16 симв.), AUTH_ALLOW_DEV_TOKEN=false, AUTH_REQUIRE_AUTH=true,
# AUTH_COOKIE_SECURE=true — иначе приложение падает на старте/security-readiness.
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_SESSION_COOKIE_NAME=botfleet_session
AUTH_REFRESH_COOKIE_NAME=botfleet_refresh
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_HTTPONLY=true
AUTH_COOKIE_AUTH_ENABLED=false
AUTH_ALLOW_DEV_TOKEN=true
AUTH_REQUIRE_AUTH=false

# --- CSRF (для cookie-auth) ---
CSRF_PROTECTION_ENABLED=false
CSRF_COOKIE_NAME=botfleet_csrf

# --- Rate limiting (in-memory MVP; для распределённого prod — Redis) ---
RATE_LIMIT_ENABLED=false
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=120
RATE_LIMIT_PAYMENT_PER_MINUTE=30

# --- Security headers ---
SECURITY_HEADERS_ENABLED=true

# --- Хранилища ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_smm_bot
REDIS_URL=redis://localhost:6379/0

# --- Внешние интеграции (заполняются на соответствующих этапах) ---
# Яндекс Диск (Этап 2). Токен — OAuth-токен Яндекс.Диска; без него синхронизация
# недоступна (sync-эндпоинты вернут 503), но остальной API работает.
YANDEX_DISK_TOKEN=
YANDEX_DISK_BASE_URL=https://cloud-api.yandex.net/v1/disk
YANDEX_DISK_ROOT_PATH=/SMM_BOT
# Публичный режим Яндекс Диска (альтернатива OAuth-токену). Если включён,
# sync-media читает медиа по публичной ссылке без токена. Папки: внутри SMM
# лежат «Тион» и «Фабрика сувениров»; teeon видит только «Тион», fabric-souvenirs
# видит «Тион» + «Фабрика сувениров».
YANDEX_DISK_PUBLIC_MODE=false
YANDEX_DISK_PUBLIC_SMM_URL=
YANDEX_DISK_PUBLIC_ROOT_FOLDER=SMM
# Автопостинг (Этап 7). Без токенов реальная публикация недоступна (понятная
# ошибка), но планирование, API и тесты работают. Instagram на Этапе 7 не подключён.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHANNEL_ID=
VK_ACCESS_TOKEN=
VK_DEFAULT_GROUP_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Instagram Graph API / OAuth через Meta App. APP_ID / REDIRECT_URI / USER_ID —
# несекретные справочные значения; APP_SECRET и ACCESS_TOKEN — секреты (не коммитить,
# в UI показывается только факт наличия/маска). REDIRECT_URI пуст ⇒ выводится из
# PUBLIC_APP_URL. Публикация фото требует публичного HTTPS image_url.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=
INSTAGRAM_USER_ID=
# Видео-платформы (adapter-скелеты; live пока не реализован).
YOUTUBE_ACCESS_TOKEN=
YOUTUBE_CHANNEL_ID=
RUTUBE_ACCESS_TOKEN=
RUTUBE_CHANNEL_ID=

# Живая (РЕАЛЬНАЯ) публикация в соцсети. По умолчанию false — без этих флагов
# отправка невозможна (защита от случайной публикации). Для Instagram/YouTube/RuTube
# даже с флагом live пока не реализован (понятная ошибка); dry-run/preview работает.
TELEGRAM_LIVE_PUBLISHING_ENABLED=false
VK_LIVE_PUBLISHING_ENABLED=false
INSTAGRAM_LIVE_PUBLISHING_ENABLED=false
YOUTUBE_LIVE_PUBLISHING_ENABLED=false
RUTUBE_LIVE_PUBLISHING_ENABLED=false

# Максимум фото в одном Telegram-посте с альбомом (sendMediaGroup, до 10).
TELEGRAM_MEDIA_GROUP_MAX_PHOTOS=10

# --- VK API photo upload strategy (без OAuth/браузера) ---
# auto — сначала wall (photos.getWallUploadServer), при error 27 — album
# (photos.getUploadServer/photos.save в альбом группы). Варианты: auto|wall|album.
VK_PHOTO_UPLOAD_STRATEGY=auto
VK_PHOTO_ALBUM_ID=
VK_PHOTO_ALBUM_TITLE=AI SMM Bot uploads
VK_PHOTO_PROBE_ALLOW_UPLOAD=false

# --- SEO-заполнение VK-группы (SEO VK Group Setup) ---
# Реальные изменения оформления VK-группы (название/описание/статус/закреп/меню).
# По умолчанию false — apply работает только как preview/dry-run, реальные вызовы
# VK API оформления группы не выполняются. VK_GROUP_SETUP_ALLOWED_PROJECTS —
# список project_slug (через запятую), которым разрешено SEO-заполнение.
VK_GROUP_SETUP_LIVE_ENABLED=false
VK_GROUP_SETUP_ALLOWED_PROJECTS=teeon,fabric-souvenirs

# --- Публичный адрес приложения (для VK OAuth callback) ---
# Продакшн-домен с HTTPS. Из него выводится VK_OAUTH_REDIRECT_URI, если тот пуст.
PUBLIC_APP_URL=https://app.teeon.ru

# --- VK OAuth (подключение ПОЛЬЗОВАТЕЛЬСКОГО токена через кнопку) ---
# Standalone-приложение VK для OAuth: пользователь сам выдаёт доступ (scope
# wall,photos,groups,offline), фото грузятся его user-token, НЕ ключом сообщества.
# VK_APP_SECRET не логируется; полученный токен хранится в секрете ресурса (маска).
# VK требует HTTPS-redirect. Оставьте VK_OAUTH_REDIRECT_URI пустым — он выведется из
# PUBLIC_APP_URL + /integrations/vk/oauth/callback (для локали задайте PUBLIC_APP_URL
# или VK_OAUTH_REDIRECT_URI явно). В VK ID приложении добавьте базовый домен и этот URL.
VK_APP_ID=54671660
VK_APP_SECRET=
VK_OAUTH_REDIRECT_URI=

# --- AI-провайдер ---
AI_PROVIDER=stub
AI_API_KEY=
# Модель и цены токенов (USD за 1M токенов). Меняйте под реальный тариф провайдера —
# юнит-экономика пересчитается без правок кода. Значения ниже — ориентир.
AI_PRICING_MODEL=gpt-5.4-mini
AI_INPUT_USD_PER_1M=0.75
AI_OUTPUT_USD_PER_1M=4.50

# --- Биллинг / юнит-экономика (units — внутренняя валюта Botfleet) ---
# себестоимость_usd = in/1M*in_price + out/1M*out_price
# цена_клиента_usd  = себестоимость_usd * markup_multiplier
# units = max(min_units, ceil(цена_клиента_usd * usd_to_unit_rate))
BILLING_MARKUP_MULTIPLIER=2.0
BILLING_USD_TO_UNIT_RATE=100.0
BILLING_MIN_POST_UNITS=5
BILLING_MIN_ANALYTICS_UNITS=3
# Ориентировочная цена 1 unit в рублях (для суммы счёта; реальных платежей нет).
BILLING_UNIT_PRICE_RUB=1.0

# --- Аналитика: фиксированные цены по глубине (units за пост) ---
ANALYTICS_LIGHT_UNITS=10
ANALYTICS_STANDARD_UNITS=20
ANALYTICS_DEEP_UNITS=40

# --- Платежи (Россия). РЕАЛЬНЫЕ ПЛАТЕЖИ ВЫКЛЮЧЕНЫ по умолчанию ---
# Без PAYMENTS_LIVE_ENABLED=true все счета — mock/sandbox; баланс пополняется только
# после статуса paid (mock-pay/webhook). Секреты провайдеров НЕ коммитить: заполняются
# в реальном .env, в UI показываются только маской.
# PAYMENTS_PROVIDER_HTTP_ENABLED — разрешить реальные сетевые вызовы к API провайдера.
# По умолчанию false: даже с sandbox-флагом сеть не вызывается (строится fake-invoice).
# *_SANDBOX_ENABLED — включить sandbox-adapter провайдера (детерминированные fake-счета
# без сети) для e2e-прогонов оплаты. НЕ включает боевой эквайринг.
PAYMENTS_LIVE_ENABLED=false
PAYMENTS_DEFAULT_PROVIDER=mock
PAYMENTS_PROVIDER_HTTP_ENABLED=false
PAYMENTS_SUCCESS_RETURN_URL=
PAYMENTS_FAIL_RETURN_URL=
# YooKassa (ЮKassa) — sandbox adapter
YOOKASSA_SANDBOX_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=
YOOKASSA_RETURN_URL=
YOOKASSA_CONFIRMATION_TYPE=redirect
# T-Bank / Тинькофф (sandbox skeleton)
TBANK_SANDBOX_ENABLED=false
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=
# CloudPayments (sandbox skeleton)
CLOUDPAYMENTS_SANDBOX_ENABLED=false
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=
# Robokassa (planned skeleton)
ROBOKASSA_SANDBOX_ENABLED=false
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=

# --- Улучшение медиа (Media Enhancement) ---
# Создание улучшенных КОПИЙ изображений (оригиналы не меняются). Локально, без AI.
MEDIA_ENHANCEMENT_ENABLED=false
MEDIA_ENHANCEMENT_STORAGE_DIR=backend/data/enhanced_media
MEDIA_ENHANCEMENT_MAX_IMAGE_MB=25
MEDIA_ENHANCEMENT_DEFAULT_PROFILE=social_safe
MEDIA_ENHANCEMENT_OUTPUT_FORMAT=jpg
MEDIA_ENHANCEMENT_JPEG_QUALITY=92

# --- Media Proxy: временные публичные HTTPS-ссылки на медиа (для Instagram) ---
# Instagram публикует по публичному image_url. Botfleet отдаёт медиа по временной
# ссылке https://<base>/media/public/{token}: токен случайный, хранится только хеш,
# ссылка ограничена по времени и отзывается. Если MEDIA_PROXY_PUBLIC_BASE_URL пуст —
# берётся PUBLIC_APP_URL / APP_BASE_URL. В production нужен HTTPS-домен (не localhost).
MEDIA_PROXY_ENABLED=true
MEDIA_PROXY_PUBLIC_BASE_URL=
MEDIA_PROXY_DEFAULT_TTL_SECONDS=86400
MEDIA_PROXY_MAX_TTL_SECONDS=604800
MEDIA_PROXY_MAX_BYTES=15728640
MEDIA_PROXY_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp
MEDIA_PROXY_REQUIRE_HTTPS_IN_PRODUCTION=true
MEDIA_PROXY_TOKEN_BYTES=32
MEDIA_PROXY_CACHE_DIR=tmp/media_proxy_cache
MEDIA_PROXY_CACHE_ENABLED=true

# --- Background scheduler worker (движок автоматизации расписаний) ---
# По умолчанию worker ВЫКЛЮЧЕН и в dry-run. Даже включённый worker НИКОГДА не публикует
# live — только draft/needs_review. В production запускается ОТДЕЛЬНЫМ процессом/контейнером
# (не внутри web). DRY_RUN=true → только preview/log; DRY_RUN=false + CREATE_DRAFTS=true →
# создаёт draft/needs_review. Allowlist пустой = все доступные account/platform.
SCHEDULER_WORKER_ENABLED=false
SCHEDULER_WORKER_INTERVAL_SECONDS=60
SCHEDULER_WORKER_BATCH_SIZE=20
SCHEDULER_WORKER_DRY_RUN=true
SCHEDULER_WORKER_CREATE_DRAFTS=true
SCHEDULER_WORKER_LOCK_TTL_SECONDS=300
SCHEDULER_WORKER_MAX_PROJECTS_PER_TICK=50
SCHEDULER_WORKER_PLATFORM_ALLOWLIST=
SCHEDULER_WORKER_ACCOUNT_ALLOWLIST=

# --- A/B-тестирование и оптимизация тем (v0.4.2) ---
# A/B-эксперименты доступны через UI/API. Авто-применение winner и авто-создание
# экспериментов worker-ом ВЫКЛЮЧЕНЫ по умолчанию. Live-публикаций это не подразумевает.
AB_TESTING_ENABLED=true
AB_TESTING_AUTO_WINNER_ENABLED=false
AB_TESTING_DEFAULT_VARIANT_COUNT=2
AB_TESTING_MAX_VARIANTS=3
AB_TESTING_MIN_CONFIDENCE_TO_AUTO_APPLY=0.7
SCHEDULE_EXPERIMENTS_ENABLED=false
TOPIC_OPTIMIZATION_ENABLED=true
TOPIC_OPTIMIZATION_RECENCY_DAYS=60
TOPIC_OPTIMIZATION_MAX_RECOMMENDATIONS=10

# --- Предложения экспериментов worker-ом (v0.4.3) ---
# Worker может предлагать эксперименты/темы, но НЕ публикует live. Генерация worker-ом и
# авто-создание экспериментов ВЫКЛЮЧЕНЫ по умолчанию; даже auto-create делает только draft.
EXPERIMENT_SUGGESTIONS_ENABLED=true
EXPERIMENT_SUGGESTIONS_WORKER_ENABLED=false
EXPERIMENT_SUGGESTIONS_DRY_RUN=true
EXPERIMENT_SUGGESTIONS_AUTO_CREATE=false
EXPERIMENT_SUGGESTIONS_MAX_PER_TICK=5
EXPERIMENT_SUGGESTIONS_MAX_ACTIVE_PER_PROJECT=20
EXPERIMENT_SUGGESTIONS_MIN_CONFIDENCE=0.55
EXPERIMENT_SUGGESTIONS_COOLDOWN_HOURS=24
EXPERIMENT_SUGGESTIONS_EXPIRE_DAYS=14
EXPERIMENT_SUGGESTIONS_REQUIRE_REVIEW=true

# --- Автовыбор темы worker-ом (v0.4.4) ---
# Worker сам выбирает тему/CTA/формат/медиа для ближайшего слота по обучению/метрикам/
# A/B winners/suggestions, но НЕ публикует live. Автовыбор worker-ом ВЫКЛЮЧЕН по умолчанию.
AUTO_TOPIC_SELECTION_ENABLED=true
AUTO_TOPIC_SELECTION_WORKER_ENABLED=false
AUTO_TOPIC_SELECTION_DRY_RUN=true
AUTO_TOPIC_SELECTION_MIN_CONFIDENCE=0.55
AUTO_TOPIC_SELECTION_MAX_ALTERNATIVES=5
AUTO_TOPIC_SELECTION_RECENCY_DAYS=60
AUTO_TOPIC_SELECTION_FATIGUE_WINDOW_DAYS=14
AUTO_TOPIC_SELECTION_REQUIRE_MEDIA_FOR_MEDIA_PLANS=false
AUTO_TOPIC_SELECTION_USE_AB_WINNERS=true
AUTO_TOPIC_SELECTION_USE_EXPERIMENT_SUGGESTIONS=true
AUTO_TOPIC_SELECTION_USE_METRICS=true
AUTO_TOPIC_SELECTION_USE_CLIENT_FEEDBACK=true
AUTO_TOPIC_SELECTION_FALLBACK_TO_CRM_CATEGORY=true

# --- Автовыбор медиа worker-ом (v0.4.5) ---
# Worker сам выбирает media strategy и медиа для слота, но НЕ публикует live и НЕ создаёт
# публичные ссылки автоматически. Автовыбор worker-ом ВЫКЛЮЧЕН по умолчанию; dry-run.
AUTO_MEDIA_SELECTION_ENABLED=true
AUTO_MEDIA_SELECTION_WORKER_ENABLED=false
AUTO_MEDIA_SELECTION_DRY_RUN=true
AUTO_MEDIA_SELECTION_MIN_CONFIDENCE=0.50
AUTO_MEDIA_SELECTION_RECENCY_DAYS=60
AUTO_MEDIA_SELECTION_FATIGUE_WINDOW_DAYS=14
AUTO_MEDIA_SELECTION_MAX_IMAGES_TELEGRAM=10
AUTO_MEDIA_SELECTION_MAX_IMAGES_VK=5
AUTO_MEDIA_SELECTION_MAX_IMAGES_INSTAGRAM=10
AUTO_MEDIA_SELECTION_REQUIRE_MEDIA_FOR_MEDIA_PLANS=false
AUTO_MEDIA_SELECTION_USE_AB_WINNERS=true
AUTO_MEDIA_SELECTION_USE_METRICS=true
AUTO_MEDIA_SELECTION_USE_CLIENT_FEEDBACK=true
AUTO_MEDIA_SELECTION_CREATE_PUBLIC_LINKS=false

# --- Оценка качества медиа (v0.4.6) ---
# Правило-ориентированная оценка качества/релевантности/свежести/уникальности/пригодности
# медиа + выявление дублей. БЕЗ внешнего AI и БЕЗ live-публикаций. Оценка worker-ом
# ВЫКЛЮЧЕНА по умолчанию; dry-run; авто-ретегирование выключено.
MEDIA_QUALITY_SCORING_ENABLED=true
MEDIA_QUALITY_SCORING_WORKER_ENABLED=false
MEDIA_QUALITY_SCORING_DRY_RUN=true
MEDIA_QUALITY_MIN_GOOD_SCORE=70
MEDIA_QUALITY_MIN_EXCELLENT_SCORE=85
MEDIA_QUALITY_RECENCY_DAYS=60
MEDIA_QUALITY_FATIGUE_WINDOW_DAYS=14
MEDIA_QUALITY_MAX_SNAPSHOTS_PER_ASSET=20
MEDIA_QUALITY_DEDUP_ENABLED=true
MEDIA_QUALITY_PLATFORM_WEIGHTING_ENABLED=true
MEDIA_QUALITY_AUTO_RETAGS_ENABLED=false
MEDIA_QUALITY_EXTERNAL_AI_ENABLED=false

# --- Fingerprint и дедупликация медиа (v0.4.7) ---
# Локальные fingerprint (sha256/perceptual/average/difference hash + сигнатуры) и кластеры
# дублей. БЕЗ внешнего AI/vision, БЕЗ сети по умолчанию (Yandex-скачивание выключено), БЕЗ
# авто-удаления/скрытия. Fingerprint worker-ом ВЫКЛЮЧЕН по умолчанию; dry-run.
MEDIA_FINGERPRINTING_ENABLED=true
MEDIA_FINGERPRINTING_WORKER_ENABLED=false
MEDIA_FINGERPRINTING_DRY_RUN=true
MEDIA_FINGERPRINTING_MAX_ASSETS_PER_RUN=200
MEDIA_FINGERPRINTING_USE_IMAGE_BYTES=true
MEDIA_FINGERPRINTING_USE_VARIANTS=true
MEDIA_FINGERPRINTING_USE_YANDEX_DOWNLOAD=false
MEDIA_FINGERPRINTING_EXTERNAL_AI_ENABLED=false
MEDIA_SIMILARITY_DEDUP_ENABLED=true
MEDIA_SIMILARITY_EXACT_HASH_THRESHOLD=1.0
MEDIA_SIMILARITY_NEAR_HASH_DISTANCE=6
MEDIA_SIMILARITY_TAG_WEIGHT=0.2
MEDIA_SIMILARITY_VISUAL_WEIGHT=0.8
MEDIA_DUPLICATE_CLUSTER_MIN_SCORE=0.82
MEDIA_DUPLICATE_AUTO_HIDE_ENABLED=false
MEDIA_DUPLICATE_AUTO_DELETE_ENABLED=false

# --- Курирование медиатеки (v0.4.8) ---
# Задачи очистки/разметки медиатеки (дубли, ретегинг, слабые медиа). Теги применяются ТОЛЬКО
# после подтверждения клиента; файлы НЕ удаляются; внешнего AI нет. Курирование worker-ом
# ВЫКЛЮЧЕНО по умолчанию; dry-run; авто-применение/скрытие/удаление выключены.
MEDIA_CURATION_ENABLED=true
MEDIA_CURATION_WORKER_ENABLED=false
MEDIA_CURATION_DRY_RUN=true
MEDIA_CURATION_AUTO_APPLY_TAGS=false
MEDIA_CURATION_AUTO_HIDE_DUPLICATES=false
MEDIA_CURATION_AUTO_DELETE_ENABLED=false
MEDIA_CURATION_MAX_TASKS_PER_RUN=100
MEDIA_CURATION_MIN_CONFIDENCE=0.55
MEDIA_CURATION_TASK_EXPIRE_DAYS=30
MEDIA_CURATION_USE_FINGERPRINTS=true
MEDIA_CURATION_USE_QUALITY=true
MEDIA_CURATION_USE_LEARNING=true
MEDIA_CURATION_EXTERNAL_AI_ENABLED=false

# --- Collaborative media curation review (v0.4.9) ---
# Ревью медиатеки: задачи, ответственные, комментарии, история решений. Изменения (теги/
# видимость) применяются ТОЛЬКО после approved; авто-применение и уведомления выключены;
# внешнего AI нет; файлы не удаляются; live-публикаций/платежей не подразумевает.
MEDIA_CURATION_REVIEW_ENABLED=true
MEDIA_CURATION_REVIEW_REQUIRE_APPROVAL=true
MEDIA_CURATION_REVIEW_ALLOW_SELF_APPROVAL=true
MEDIA_CURATION_REVIEW_DEFAULT_PRIORITY=normal
MEDIA_CURATION_REVIEW_OVERDUE_DAYS=7
MEDIA_CURATION_REVIEW_MAX_COMMENTS_PER_TASK=100
MEDIA_CURATION_REVIEW_NOTIFY_ENABLED=false
MEDIA_CURATION_REVIEW_AUTO_APPLY_AFTER_APPROVAL=false
MEDIA_CURATION_REVIEW_EXTERNAL_AI_ENABLED=false

# --- Notifications, mentions, reviewer workload (v0.5.0) ---
# Внутренние (in-app) уведомления, упоминания и нагрузка ревьюеров. Внешняя доставка
# (email/digest/webhook/push) ВЫКЛЮЧЕНА по умолчанию и в MVP не отправляется; worker выключен;
# dry-run по умолчанию; live-публикаций/платежей не подразумевает.
NOTIFICATIONS_ENABLED=true
