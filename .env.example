NOTIFICATION_TELEGRAM_WEBHOOK_PUBLIC_URL=
NOTIFICATION_TELEGRAM_WEBHOOK_PATH=/notification-telegram/webhook
NOTIFICATION_TELEGRAM_WEBHOOK_ALLOW_LOCAL_WITHOUT_SECRET=true
NOTIFICATION_TELEGRAM_POLLING_ENABLED=true
NOTIFICATION_TELEGRAM_POLLING_LIVE_ENABLED=false
NOTIFICATION_TELEGRAM_POLLING_DRY_RUN=true
NOTIFICATION_TELEGRAM_POLLING_LIMIT=20
NOTIFICATION_TELEGRAM_WEBHOOK_MANAGEMENT_ENABLED=true
