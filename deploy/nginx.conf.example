# Пример nginx-конфигурации для Botfleet (опционально; Caddy проще для HTTPS).
# TLS-сертификаты нужно получить отдельно (certbot / acme.sh). Замените домен и пути.
#
# Приложение слушает app:8000 (или 127.0.0.1:8000 при deploy без docker).

upstream botfleet_app {
    server app:8000;
}

# HTTP → HTTPS редирект.
server {
    listen 80;
    server_name app.botfleet.ru;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name app.botfleet.ru;

    # Пути к сертификатам (получить через certbot):
    ssl_certificate     /etc/letsencrypt/live/app.botfleet.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/app.botfleet.ru/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    # HSTS (приложение тоже ставит его в production).
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    client_max_body_size 25m;

    location / {
        proxy_pass http://botfleet_app;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}
