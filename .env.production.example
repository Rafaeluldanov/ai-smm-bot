# ============================================================================
# Botfleet — ПРИМЕР production-окружения (.env.production.example)
# ----------------------------------------------------------------------------
# Скопируйте в .env.production и заполните ТОЛЬКО на сервере / в secret manager.
# ЗДЕСЬ ТОЛЬКО ПЛЕЙСХОЛДЕРЫ — реальные секреты в Git НЕ попадают.
#
# ВАЖНО:
#   • AUTH_TOKEN_SECRET — длинный, случайный, 32–64+ символа. Сгенерируйте:
#       python -c "import secrets; print(secrets.token_urlsafe(48))"
#   • PAYMENTS_LIVE_ENABLED НЕЛЬЗЯ включать до аудита sandbox/webhook-подписей.
#   • Live-публикации (*_LIVE_PUBLISHING_ENABLED) нельзя включать без отдельных
#     платформенных тестов.
#   • Секреты хранить в secret manager / server env, не в Git.
#   • Проверка перед запуском: make prod-check  и  /health/security-readiness.
# ============================================================================

# --- Приложение ---
APP_ENV=production
APP_BASE_URL=https://app.botfleet.ru
PUBLIC_APP_URL=https://app.botfleet.ru
LOG_LEVEL=INFO

# --- Хранилища (внутри docker-compose: хосты db / redis) ---
DATABASE_URL=postgresql+psycopg2://botfleet:CHANGE_ME@db:5432/botfleet
REDIS_URL=redis://redis:6379/0

# --- Auth / session (production-hardening) ---
# AUTH_TOKEN_SECRET — обязателен и надёжен; иначе приложение НЕ стартует.
AUTH_TOKEN_SECRET=CHANGE_ME_GENERATE_64_CHARS
AUTH_ALLOW_DEV_TOKEN=false
AUTH_REQUIRE_AUTH=true
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_HTTPONLY=true
CSRF_PROTECTION_ENABLED=true
RATE_LIMIT_ENABLED=true
SECURITY_HEADERS_ENABLED=true

# --- Прочая безопасность ---
SECURITY_HIDE_LEGACY_PROJECTS_IN_PROD=true
PAID_ACTIONS_ENFORCED=true
AUDIT_LOG_ENABLED=true

# --- Платежи (боевой эквайринг ВЫКЛЮЧЕН до аудита) ---
# Включать PAYMENTS_LIVE_ENABLED только после: договора с провайдером, shop/merchant id,
# webhook URL + проверки подписи, успешного sandbox-прогона и юр./бух. чек-листа.
# PAYMENTS_PROVIDER_HTTP_ENABLED и *_SANDBOX_ENABLED в production держим false.
PAYMENTS_LIVE_ENABLED=false
PAYMENTS_DEFAULT_PROVIDER=mock
PAYMENTS_PROVIDER_HTTP_ENABLED=false
# YooKassa (ЮKassa) — секреты только в secret manager, НЕ в Git.
YOOKASSA_SANDBOX_ENABLED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=
YOOKASSA_RETURN_URL=https://app.botfleet.ru/ui/billing
YOOKASSA_CONFIRMATION_TYPE=redirect
# T-Bank / CloudPayments / Robokassa (sandbox выключен; секреты в secret manager)
TBANK_SANDBOX_ENABLED=false
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=
CLOUDPAYMENTS_SANDBOX_ENABLED=false
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=
ROBOKASSA_SANDBOX_ENABLED=false
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=

# --- Telegram (live публикация выключена) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHANNEL_ID=
TELEGRAM_LIVE_PUBLISHING_ENABLED=false

# --- VK (live публикация выключена) ---
VK_ACCESS_TOKEN=
VK_DEFAULT_GROUP_ID=
VK_APP_ID=
VK_APP_SECRET=
VK_OAUTH_REDIRECT_URI=https://app.botfleet.ru/integrations/vk/oauth/callback
VK_LIVE_PUBLISHING_ENABLED=false

# --- Instagram (live публикация выключена) ---
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://app.botfleet.ru/integrations/instagram/oauth/callback
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
INSTAGRAM_LIVE_PUBLISHING_ENABLED=false

# --- Яндекс Диск (медиа-источник) ---
YANDEX_DISK_TOKEN=
YANDEX_DISK_PUBLIC_MODE=true
YANDEX_DISK_PUBLIC_SMM_URL=

# --- Media Proxy (публичные HTTPS-ссылки на медиа для Instagram) ---
# В production обязателен HTTPS-домен (не localhost). Если пусто — берётся PUBLIC_APP_URL.
MEDIA_PROXY_ENABLED=true
MEDIA_PROXY_PUBLIC_BASE_URL=https://app.botfleet.ru
MEDIA_PROXY_DEFAULT_TTL_SECONDS=86400
MEDIA_PROXY_MAX_TTL_SECONDS=604800
MEDIA_PROXY_MAX_BYTES=15728640
MEDIA_PROXY_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp
MEDIA_PROXY_REQUIRE_HTTPS_IN_PRODUCTION=true
MEDIA_PROXY_TOKEN_BYTES=32
MEDIA_PROXY_CACHE_DIR=tmp/media_proxy_cache
MEDIA_PROXY_CACHE_ENABLED=true

# --- Background scheduler worker (ОТДЕЛЬНЫЙ процесс/контейнер, не внутри web) ---
# Даже включённый worker НЕ публикует live — только draft/needs_review. Держим выключенным
# и в dry-run по умолчанию; включать осознанно на отдельном контейнере scheduler-worker.
SCHEDULER_WORKER_ENABLED=false
SCHEDULER_WORKER_INTERVAL_SECONDS=60
SCHEDULER_WORKER_BATCH_SIZE=20
SCHEDULER_WORKER_DRY_RUN=true
SCHEDULER_WORKER_CREATE_DRAFTS=true
SCHEDULER_WORKER_LOCK_TTL_SECONDS=300
SCHEDULER_WORKER_MAX_PROJECTS_PER_TICK=50
SCHEDULER_WORKER_PLATFORM_ALLOWLIST=
SCHEDULER_WORKER_ACCOUNT_ALLOWLIST=

# --- AI-провайдер (заглушка; реальный ключ — только в server env) ---
AI_PROVIDER=stub
AI_API_KEY=

# --- A/B-тестирование и оптимизация тем (v0.4.2) ---
# В production авто-применение winner и авто-создание экспериментов worker-ом должны
# оставаться ВЫКЛЮЧЕННЫМИ до аудита. Live-публикаций это не подразумевает.
AB_TESTING_ENABLED=true
AB_TESTING_AUTO_WINNER_ENABLED=false
AB_TESTING_DEFAULT_VARIANT_COUNT=2
AB_TESTING_MAX_VARIANTS=3
AB_TESTING_MIN_CONFIDENCE_TO_AUTO_APPLY=0.7
SCHEDULE_EXPERIMENTS_ENABLED=false
TOPIC_OPTIMIZATION_ENABLED=true
TOPIC_OPTIMIZATION_RECENCY_DAYS=60
TOPIC_OPTIMIZATION_MAX_RECOMMENDATIONS=10

# --- Предложения экспериментов worker-ом (v0.4.3) ---
# Worker может предлагать эксперименты/темы, но НЕ публикует live. Генерация worker-ом и
# авто-создание экспериментов ВЫКЛЮЧЕНЫ по умолчанию; даже auto-create делает только draft.
EXPERIMENT_SUGGESTIONS_ENABLED=true
EXPERIMENT_SUGGESTIONS_WORKER_ENABLED=false
EXPERIMENT_SUGGESTIONS_DRY_RUN=true
EXPERIMENT_SUGGESTIONS_AUTO_CREATE=false
EXPERIMENT_SUGGESTIONS_MAX_PER_TICK=5
EXPERIMENT_SUGGESTIONS_MAX_ACTIVE_PER_PROJECT=20
EXPERIMENT_SUGGESTIONS_MIN_CONFIDENCE=0.55
EXPERIMENT_SUGGESTIONS_COOLDOWN_HOURS=24
EXPERIMENT_SUGGESTIONS_EXPIRE_DAYS=14
EXPERIMENT_SUGGESTIONS_REQUIRE_REVIEW=true

# --- Автовыбор темы worker-ом (v0.4.4) ---
# Worker сам выбирает тему/CTA/формат/медиа, но НЕ публикует live. Выключено по умолчанию.
AUTO_TOPIC_SELECTION_ENABLED=true
AUTO_TOPIC_SELECTION_WORKER_ENABLED=false
AUTO_TOPIC_SELECTION_DRY_RUN=true
AUTO_TOPIC_SELECTION_MIN_CONFIDENCE=0.55
AUTO_TOPIC_SELECTION_MAX_ALTERNATIVES=5
AUTO_TOPIC_SELECTION_RECENCY_DAYS=60
AUTO_TOPIC_SELECTION_FATIGUE_WINDOW_DAYS=14
AUTO_TOPIC_SELECTION_REQUIRE_MEDIA_FOR_MEDIA_PLANS=false
AUTO_TOPIC_SELECTION_USE_AB_WINNERS=true
AUTO_TOPIC_SELECTION_USE_EXPERIMENT_SUGGESTIONS=true
AUTO_TOPIC_SELECTION_USE_METRICS=true
AUTO_TOPIC_SELECTION_USE_CLIENT_FEEDBACK=true
AUTO_TOPIC_SELECTION_FALLBACK_TO_CRM_CATEGORY=true

# --- Автовыбор медиа worker-ом (v0.4.5) ---
# Worker сам выбирает media strategy и медиа, но НЕ публикует live и НЕ создаёт публичные
# ссылки автоматически. Выключено по умолчанию.
AUTO_MEDIA_SELECTION_ENABLED=true
AUTO_MEDIA_SELECTION_WORKER_ENABLED=false
AUTO_MEDIA_SELECTION_DRY_RUN=true
AUTO_MEDIA_SELECTION_MIN_CONFIDENCE=0.50
AUTO_MEDIA_SELECTION_RECENCY_DAYS=60
AUTO_MEDIA_SELECTION_FATIGUE_WINDOW_DAYS=14
AUTO_MEDIA_SELECTION_MAX_IMAGES_TELEGRAM=10
AUTO_MEDIA_SELECTION_MAX_IMAGES_VK=5
AUTO_MEDIA_SELECTION_MAX_IMAGES_INSTAGRAM=10
AUTO_MEDIA_SELECTION_REQUIRE_MEDIA_FOR_MEDIA_PLANS=false
AUTO_MEDIA_SELECTION_USE_AB_WINNERS=true
AUTO_MEDIA_SELECTION_USE_METRICS=true
AUTO_MEDIA_SELECTION_USE_CLIENT_FEEDBACK=true
AUTO_MEDIA_SELECTION_CREATE_PUBLIC_LINKS=false

# --- Оценка качества медиа (v0.4.6) ---
# Правило-ориентированная оценка качества/релевантности/свежести/уникальности/пригодности
# медиа + выявление дублей. БЕЗ внешнего AI и БЕЗ live-публикаций. Оценка worker-ом
# ВЫКЛЮЧЕНА по умолчанию; dry-run; авто-ретегирование выключено.
MEDIA_QUALITY_SCORING_ENABLED=true
MEDIA_QUALITY_SCORING_WORKER_ENABLED=false
MEDIA_QUALITY_SCORING_DRY_RUN=true
MEDIA_QUALITY_MIN_GOOD_SCORE=70
MEDIA_QUALITY_MIN_EXCELLENT_SCORE=85
MEDIA_QUALITY_RECENCY_DAYS=60
MEDIA_QUALITY_FATIGUE_WINDOW_DAYS=14
MEDIA_QUALITY_MAX_SNAPSHOTS_PER_ASSET=20
MEDIA_QUALITY_DEDUP_ENABLED=true
MEDIA_QUALITY_PLATFORM_WEIGHTING_ENABLED=true
MEDIA_QUALITY_AUTO_RETAGS_ENABLED=false
MEDIA_QUALITY_EXTERNAL_AI_ENABLED=false

# --- Fingerprint и дедупликация медиа (v0.4.7) ---
# Локальные fingerprint (sha256/perceptual/average/difference hash + сигнатуры) и кластеры
# дублей. БЕЗ внешнего AI/vision, БЕЗ сети по умолчанию (Yandex-скачивание выключено), БЕЗ
# авто-удаления/скрытия. Fingerprint worker-ом ВЫКЛЮЧЕН по умолчанию; dry-run.
MEDIA_FINGERPRINTING_ENABLED=true
MEDIA_FINGERPRINTING_WORKER_ENABLED=false
MEDIA_FINGERPRINTING_DRY_RUN=true
MEDIA_FINGERPRINTING_MAX_ASSETS_PER_RUN=200
MEDIA_FINGERPRINTING_USE_IMAGE_BYTES=true
MEDIA_FINGERPRINTING_USE_VARIANTS=true
MEDIA_FINGERPRINTING_USE_YANDEX_DOWNLOAD=false
MEDIA_FINGERPRINTING_EXTERNAL_AI_ENABLED=false
MEDIA_SIMILARITY_DEDUP_ENABLED=true
MEDIA_SIMILARITY_EXACT_HASH_THRESHOLD=1.0
MEDIA_SIMILARITY_NEAR_HASH_DISTANCE=6
MEDIA_SIMILARITY_TAG_WEIGHT=0.2
MEDIA_SIMILARITY_VISUAL_WEIGHT=0.8
MEDIA_DUPLICATE_CLUSTER_MIN_SCORE=0.82
MEDIA_DUPLICATE_AUTO_HIDE_ENABLED=false
MEDIA_DUPLICATE_AUTO_DELETE_ENABLED=false

# --- Курирование медиатеки (v0.4.8) ---
# Задачи очистки/разметки медиатеки (дубли, ретегинг, слабые медиа). Теги применяются ТОЛЬКО
# после подтверждения клиента; файлы НЕ удаляются; внешнего AI нет. Курирование worker-ом
# ВЫКЛЮЧЕНО по умолчанию; dry-run; авто-применение/скрытие/удаление выключены.
MEDIA_CURATION_ENABLED=true
MEDIA_CURATION_WORKER_ENABLED=false
MEDIA_CURATION_DRY_RUN=true
MEDIA_CURATION_AUTO_APPLY_TAGS=false
MEDIA_CURATION_AUTO_HIDE_DUPLICATES=false
MEDIA_CURATION_AUTO_DELETE_ENABLED=false
MEDIA_CURATION_MAX_TASKS_PER_RUN=100
MEDIA_CURATION_MIN_CONFIDENCE=0.55
MEDIA_CURATION_TASK_EXPIRE_DAYS=30
MEDIA_CURATION_USE_FINGERPRINTS=true
MEDIA_CURATION_USE_QUALITY=true
MEDIA_CURATION_USE_LEARNING=true
MEDIA_CURATION_EXTERNAL_AI_ENABLED=false

# --- Collaborative media curation review (v0.4.9) ---
# Ревью медиатеки: задачи, ответственные, комментарии, история решений. Изменения
# применяются ТОЛЬКО после approved; авто-применение и уведомления выключены; внешнего AI
# нет; файлы не удаляются; live-публикаций/платежей не подразумевает.
MEDIA_CURATION_REVIEW_ENABLED=true
MEDIA_CURATION_REVIEW_REQUIRE_APPROVAL=true
MEDIA_CURATION_REVIEW_ALLOW_SELF_APPROVAL=true
MEDIA_CURATION_REVIEW_DEFAULT_PRIORITY=normal
MEDIA_CURATION_REVIEW_OVERDUE_DAYS=7
MEDIA_CURATION_REVIEW_MAX_COMMENTS_PER_TASK=100
MEDIA_CURATION_REVIEW_NOTIFY_ENABLED=false
MEDIA_CURATION_REVIEW_AUTO_APPLY_AFTER_APPROVAL=false
MEDIA_CURATION_REVIEW_EXTERNAL_AI_ENABLED=false

# --- Notifications, mentions, reviewer workload (v0.5.0) ---
# Внутренние (in-app) уведомления. Внешняя доставка (email/digest/webhook/push) ВЫКЛЮЧЕНА по
# умолчанию и в MVP не отправляется; worker выключен; dry-run по умолчанию.
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_IN_APP_ENABLED=true
NOTIFICATIONS_EMAIL_ENABLED=false
NOTIFICATIONS_DIGEST_ENABLED=false
NOTIFICATIONS_WEBHOOK_ENABLED=false
NOTIFICATIONS_WORKER_ENABLED=false
NOTIFICATIONS_DRY_RUN=true
NOTIFICATIONS_MAX_PER_USER=500
NOTIFICATIONS_DEDUP_WINDOW_MINUTES=30
NOTIFICATIONS_MENTION_ENABLED=true
NOTIFICATIONS_OVERDUE_SCAN_ENABLED=true
NOTIFICATIONS_OVERDUE_GRACE_HOURS=24
NOTIFICATIONS_EXTERNAL_DELIVERY_ENABLED=false
MEDIA_CURATION_REVIEW_SLA_HOURS=72
POST_REVIEW_SLA_HOURS=48
EXPERIMENT_REVIEW_SLA_HOURS=72

# --- Notification delivery sandbox: email/telegram/webhook + digest (v0.5.1) ---
# Внешняя доставка уведомлений как sandbox/mock: провайдеры по умолчанию mock и НИЧЕГО не
# отправляют. РЕАЛЬНАЯ доставка (SMTP/Telegram/webhook) ВЫКЛЮЧЕНА по умолчанию; dry-run по
# умолчанию; секреты читаются из окружения и в код/логи/UI не попадают.
NOTIFICATION_DELIVERY_ENABLED=true
NOTIFICATION_DELIVERY_DRY_RUN=true
NOTIFICATION_EXTERNAL_DELIVERY_ENABLED=false

NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_EMAIL_PROVIDER=mock
NOTIFICATION_EMAIL_LIVE_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

NOTIFICATION_TELEGRAM_ENABLED=false
NOTIFICATION_TELEGRAM_PROVIDER=mock
NOTIFICATION_TELEGRAM_LIVE_ENABLED=false
NOTIFICATION_TELEGRAM_BOT_TOKEN=
NOTIFICATION_TELEGRAM_DEFAULT_CHAT_ID=

NOTIFICATION_WEBHOOK_ENABLED=false
NOTIFICATION_WEBHOOK_PROVIDER=mock
NOTIFICATION_WEBHOOK_LIVE_ENABLED=false
NOTIFICATION_WEBHOOK_SIGNING_SECRET=

NOTIFICATION_DIGEST_ENABLED=false
NOTIFICATION_DIGEST_WORKER_ENABLED=false
NOTIFICATION_DIGEST_DRY_RUN=true
NOTIFICATION_DIGEST_DEFAULT_FREQUENCY=daily
NOTIFICATION_DIGEST_MAX_NOTIFICATIONS=50

NOTIFICATION_DELIVERY_RETRY_ENABLED=true
NOTIFICATION_DELIVERY_MAX_ATTEMPTS=3
NOTIFICATION_DELIVERY_RETRY_BACKOFF_SECONDS=300

# --- Notification safety: unsubscribe, rate limits, suppression, webhooks (v0.5.2) ---
# Safety-слой ПЕРЕД реальной внешней доставкой. Реальный webhook и внешняя доставка ВЫКЛЮЧЕНЫ по
# умолчанию; секрет токена отписки и webhook-секреты — только в env, наружу не отдаются.
NOTIFICATION_SAFETY_ENABLED=true
NOTIFICATION_UNSUBSCRIBE_ENABLED=true
NOTIFICATION_UNSUBSCRIBE_TOKEN_SECRET=
NOTIFICATION_UNSUBSCRIBE_TOKEN_TTL_DAYS=365
NOTIFICATION_RATE_LIMIT_ENABLED=true
NOTIFICATION_RATE_LIMIT_EMAIL_PER_HOUR=20
NOTIFICATION_RATE_LIMIT_TELEGRAM_PER_HOUR=30
NOTIFICATION_RATE_LIMIT_WEBHOOK_PER_HOUR=60
NOTIFICATION_RATE_LIMIT_DIGEST_PER_DAY=2
NOTIFICATION_SUPPRESSION_ENABLED=true
NOTIFICATION_SUPPRESSION_FAILURE_THRESHOLD=5
NOTIFICATION_SUPPRESSION_TTL_HOURS=24
NOTIFICATION_WEBHOOK_SUBSCRIPTIONS_ENABLED=true
NOTIFICATION_WEBHOOK_SUBSCRIPTIONS_LIVE_ENABLED=false
NOTIFICATION_WEBHOOK_SIGNATURE_HEADER=X-Botfleet-Signature
NOTIFICATION_WEBHOOK_TIMESTAMP_HEADER=X-Botfleet-Timestamp
NOTIFICATION_WEBHOOK_MAX_PAYLOAD_BYTES=262144
